# AirWatch AI Service — Environment Variables
# Copy to .env and fill in values before deploying

# Path to the combined CSV training file
# Default (local): auto-resolved relative to main.py
# Koyeb: set to /data/csv/_combined_balanced.csv (volume mount)
CSV_PATH=

# Path to directory for storing trained model .joblib files
# Default (local): ai-service/models/
# Koyeb: set to /data/models (persistent volume mount)
MODEL_PATH=

# Path to SQLite database (live sensor readings from ESP32)
# Default (local): frontend/data/aqi.db
# Cloud: set to /data/aqi.db (if using volume) or leave empty to use CSV tail
DB_PATH=

# Server port (set automatically by Koyeb/Railway/Render)
PORT=8000
